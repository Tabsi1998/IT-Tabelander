DirectoryIndex index.php
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^public/index\.php$ / [R=301,L]
    RewriteRule ^public/(impressum|datenschutz|nutzungsbedingungen|contact|reviews)\.php$ /$1.php [R=301,L]
    RewriteRule ^private(/|$) - [F,L]
    RewriteRule ^README\.md$ - [F,L]
</IfModule>

<IfModule !mod_rewrite.c>
    RedirectMatch 403 ^/private(/|$)
    RedirectMatch 403 ^/README\.md$
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
